# ─── Required ───────────────────────────────────────────────────────────────
# OpenAI API key — https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-proj-...

# ─── Telegram Bot (bot only) ────────────────────────────────────────────────
# Obtain from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=123456789:ABCdef...

# ─── Data path (optional) ────────────────────────────────────────────────────
# Defaults to ../Data/mcy-vehicle-sku-mapping-v18-14.04.2026.xlsx
# DATA_PATH=/absolute/path/to/your/excel/file.xlsx

# ─── Server (optional) ───────────────────────────────────────────────────────
# PORT is set automatically by Railway; override here for local dev
# PORT=8000
